{
  "manifest_version": 2,
  "name": "OpenMail Sri Lanka",
  "version": "1.0.0",
  "applications": {
    "gecko": {
      "id": "oauth-provider@openmail.lk",
      "strict_min_version": "128.0"
    }
  },
  "oauth_provider": {
    "issuer": "https://thunder.openmail.lk/realms/openmail",
    "clientId": "<CLIENT_ID>",
    "authorizationEndpoint": "https://thunder.openmail.lk/realms/openmail/protocol/openid-connect/auth",
    "tokenEndpoint": "https://thunder.openmail.lk/realms/openmail/protocol/openid-connect/token",
    "redirectionEndpoint": "http://localhost",
    "usePKCE": true,
    "hostnames": ["openmail.lk"],
    "scopes": "openid email profile"
  }
}